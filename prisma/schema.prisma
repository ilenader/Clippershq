generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth (NextAuth) ────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("auth_accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("auth_sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("auth_verification_tokens")
}

// ─── Users ──────────────────────────────────────────────────

enum UserRole {
  CLIPPER
  ADMIN
  OWNER
  CLIENT
}

enum UserStatus {
  ACTIVE
  BANNED
  SUSPENDED
}

model User {
  id            String     @id @default(cuid())
  name          String?
  discordId     String?    @unique
  username      String     @default("user")
  email         String?    @unique
  emailVerified DateTime?
  image         String?
  role          UserRole   @default(CLIPPER)
  status        UserStatus @default(ACTIVE)
  trustScore    Int        @default(50)
  totalEarnings Float      @default(0)
  totalViews    Int        @default(0)
  level         Int        @default(0)
  bonusPercentage Float    @default(0)
  currentStreak Int        @default(0)
  longestStreak Int        @default(0)
  previousStreak Int       @default(0)
  lastActiveDate DateTime?
  referralCode  String?    @unique
  referredById  String?
  // When OWNER manually sets someone's referrer via /admin/referral-override,
  // these fields record who did it and when. Natural referrals (via link) leave
  // both null. Used so the override can be cleanly reversed without touching
  // natural referrals, and for audit/investigation.
  referrerOverriddenBy   String?
  referrerOverriddenAt   DateTime?
  manualBonusOverride Float?
  isPWAUser     Boolean    @default(false)
  lastPWAOpenAt DateTime?
  timezone      String?
  streakRestoredAt DateTime?
  // Soft-delete flag for the pre-launch reset tool (/admin/reset-data).
  // Never set on OWNER or ADMIN. Reversible via scripts/restore-deleted.ts.
  // When true: session callback force-logs the user out (src/lib/auth.ts).
  isDeleted     Boolean    @default(false)
  deletedAt     DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  // AI chatbot daily quota — replaces the old in-memory Map in src/lib/chatbot.ts
  // which reset on every container restart, silently granting users new quotas
  // after every redeploy. Persisted so limits survive deploys.
  aiMessageCount Int       @default(0)
  aiQuotaResetAt DateTime?

  // JWT session-version counter. Bumped atomically by /api/admin/users/[id]
  // PATCH whenever the user's role changes. The auth.ts JWT callback compares
  // the token's cached version against this column on a 30s lightweight
  // window — mismatch forces a full token refresh so role changes propagate
  // within ~30s instead of waiting for the 5-min resilience-floor refresh.
  sessionVersion Int       @default(0)

  // Phase 7a — cached marketplace reputation. Updated atomically in same TX
  // as rating insert. Two pairs because poster-rep and creator-rep are
  // distinct reputations — a user who's a great poster may be a mediocre
  // creator and vice versa. Aggregated card displays read these directly to
  // avoid an N+1 GROUP BY per listing card.
  marketplaceAvgAsPoster    Float?
  marketplaceCountAsPoster  Int    @default(0)
  marketplaceAvgAsCreator   Float?
  marketplaceCountAsCreator Int    @default(0)

  // Relations
  referredBy       User?     @relation("Referrals", fields: [referredById], references: [id], onDelete: SetNull)
  referrals        User[]    @relation("Referrals")
  authAccounts     Account[]
  sessions         Session[]
  clipAccounts     ClipAccount[]
  clips            Clip[]
  payoutRequests   PayoutRequest[]
  notes            Note[]
  campaignsCreated Campaign[]          @relation("CampaignsCreated")
  pendingEdits     PendingCampaignEdit[]
  campaignAdmins   CampaignAdmin[]
  teamMemberships  TeamMember[]
  auditLogs        AuditLog[]
  conversationParticipants ConversationParticipant[]
  messagesSent     Message[]
  notifications    Notification[]
  scheduledCalls   ScheduledCall[]
  campaignClients  CampaignClient[]
  // Community system — channels, tickets, scheduled voice calls
  channelMessages         ChannelMessage[]
  communityTickets        CampaignTicket[]
  communityTicketMessages TicketMessage[]
  scheduledVoiceCalls     ScheduledVoiceCall[]
  messageReactions        MessageReaction[]
  ownedCampaigns          Campaign[]          @relation("CampaignOwner")
  // Marketplace (Phase 1) — hidden feature, OWNER-only until launch flag flips.
  marketplaceListings        MarketplacePosterListing[] @relation("MarketplaceListings")
  marketplaceCreatorSubs     MarketplaceSubmission[]    @relation("MarketplaceCreatorSubmissions")
  marketplaceRatingsGiven    MarketplaceRating[]        @relation("MarketplaceRatingsGiven")
  marketplaceRatingsReceived MarketplaceRating[]        @relation("MarketplaceRatingsReceived")
  marketplaceMessages        MarketplaceMessage[]       @relation("MarketplaceMessages")
  marketplaceStrikes         MarketplaceStrike[]        @relation("MarketplaceStrikes")
  marketplaceCreatorEarnings MarketplaceCreatorEarning[] @relation("MarketplaceCreatorEarnings")

  @@index([role])
  @@index([referredById])
  @@map("users")
}

// ─── Teams ──────────────────────────────────────────────────

model Team {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members   TeamMember[]
  campaigns TeamCampaign[]

  @@map("teams")
}

model TeamMember {
  id     String @id @default(cuid())
  teamId String
  userId String
  role   String @default("MEMBER") // LEAD, MEMBER, VIEWER

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@map("team_members")
}

model TeamCampaign {
  id         String @id @default(cuid())
  teamId     String
  campaignId String

  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([teamId, campaignId])
  @@map("team_campaigns")
}

// ─── Campaigns ──────────────────────────────────────────────

enum CampaignStatus {
  ACTIVE
  PAUSED
  COMPLETED
  DRAFT
  // PAST = archival display state. Manually flagged by OWNER. Clippers see
  // these on /campaigns in a read-only horizontal strip ("previous campaigns")
  // but can't click them, can't submit clips to them, and don't see their
  // community channels. Owner can flip back to ACTIVE any time.
  PAST
}

model Campaign {
  id              String         @id @default(cuid())
  name            String
  clientName      String?
  platform        String
  status          CampaignStatus @default(DRAFT)
  pricingModel    String         @default("AGENCY_FEE") // "AGENCY_FEE" or "CPM_SPLIT"
  monetizationType String       @default("CPM") // Legacy field
  budget          Float?
  cpmRate         Float?
  clipperCpm      Float?
  ownerCpm        Float?
  agencyFee       Float?
  payoutRule      String?
  minViews        Int?
  maxPayoutPerClip Float?
  maxClipsPerUserPerDay Int     @default(3)
  // When true, creating the campaign fires broadcastCampaignAlert — DMs every
  // active clipper via Discord bot AND sends a Resend email. Defaults to false
  // so test/draft campaigns don't spam the user base; owners flip this per
  // campaign when they actually want to announce it.
  announceOnDiscord Boolean @default(false)
  description     String?        @db.Text
  requirements    String?        @db.Text
  examples        String?        @db.Text
  soundLink       String?
  assetLink       String?
  imageUrl        String?
  // Three-slot image model. Legacy imageUrl stays for backward compat so
  // old campaigns keep rendering; the display sites fall back in the
  // order [specific slot → imageUrl → default].
  cardImageUrl       String?   // 800x800, used on /campaigns list tiles
  bannerImageUrl     String?   // 1920x600, hero on /campaigns/[id]
  communityAvatarUrl String?   // 256x256 circle, community sidebar
  bannedContent   String?        @db.Text
  captionRules    String?        @db.Text
  hashtagRules    String?        @db.Text
  videoLengthMin  Int?
  videoLengthMax  Int?
  reviewTiming    String?
  aiKnowledge     String?        @db.Text
  startDate       DateTime?
  endDate         DateTime?
  createdById     String?
  isArchived         Boolean        @default(false)
  archivedAt         DateTime?
  archivedById       String?
  lastBudgetPauseAt  DateTime?
  // Only used for status=PAST display-only campaigns created in the
  // /admin/past-campaigns showcase. Normal campaigns compute spent from live
  // clip earnings; past campaigns are historical marketing tiles with no
  // clips or tracking jobs backing them, so the owner enters spent manually.
  manualSpent        Float?
  targetAudience     String?
  targetCountries    String?
  accountCountries   String?
  ownerUserId        String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  createdBy        User?   @relation("CampaignsCreated", fields: [createdById], references: [id])
  ownerUser        User?   @relation("CampaignOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  clips            Clip[]
  notes            Note[]
  campaignAccounts CampaignAccount[]
  pendingEdits     PendingCampaignEdit[]
  campaignAdmins   CampaignAdmin[]
  payoutRequests   PayoutRequest[]
  teamCampaigns    TeamCampaign[]
  trackingJobs     TrackingJob[]
  conversations    Conversation[]
  agencyEarnings   AgencyEarning[]
  campaignEvents   CampaignEvent[]
  campaignClients  CampaignClient[]
  // Community system
  channels             Channel[]
  communityTickets     CampaignTicket[]
  scheduledVoiceCalls  ScheduledVoiceCall[]
  marketplaceListings  MarketplacePosterListing[] @relation("MarketplaceListings")
  marketplaceCreatorEarnings  MarketplaceCreatorEarning[]  @relation("MarketplaceCreatorEarnings")
  marketplacePlatformEarnings MarketplacePlatformEarning[] @relation("MarketplacePlatformEarnings")

  @@index([status])
  @@index([isArchived])
  @@index([createdById])
  @@map("campaigns")
}

// ─── Clip Accounts (social media accounts) ──────────────────

enum ClipAccountStatus {
  PENDING
  VERIFIED
  APPROVED
  REJECTED
}

model ClipAccount {
  id                String           @id @default(cuid())
  userId            String
  platform          String
  username          String
  profileLink       String
  followerCount     Int?
  contentNiche      String?
  country           String?
  status            ClipAccountStatus @default(PENDING)
  rejectionReason   String?
  verificationCode  String?
  verifiedAt        DateTime?
  profileImageUrl   String?
  deletedByUser     Boolean          @default(false)
  deletedAt         DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  clips            Clip[]
  campaignAccounts CampaignAccount[]
  marketplaceListings MarketplacePosterListing[] @relation("MarketplaceListings")

  @@index([userId])
  @@map("clip_accounts")
}

// ─── Campaign Accounts (join: account ↔ campaign) ──────────

model CampaignAccount {
  id            String      @id @default(cuid())
  clipAccountId String
  campaignId    String
  joinedAt      DateTime    @default(now())

  clipAccount ClipAccount @relation(fields: [clipAccountId], references: [id], onDelete: Cascade)
  campaign    Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([clipAccountId, campaignId])
  @@map("campaign_accounts")
}

// ─── Clips ──────────────────────────────────────────────────

enum ClipStatus {
  PENDING
  APPROVED
  REJECTED
  ARCHIVED
  FLAGGED
}

model Clip {
  id              String     @id @default(cuid())
  userId          String
  campaignId      String
  clipAccountId   String
  clipUrl         String
  note            String?    @db.Text
  status          ClipStatus @default(PENDING)
  rejectionReason String?
  earnings        Float      @default(0)
  baseEarnings    Float      @default(0)
  bonusPercent    Float      @default(0)
  bonusAmount     Float      @default(0)
  isDeleted       Boolean    @default(false)
  reviewedById    String?
  reviewedAt      DateTime?
  fraudScore      Int        @default(0)
  fraudReasons    String?    @db.Text // JSON array of reason strings
  fraudCheckedAt  DateTime?
  isOwnerOverride      Boolean    @default(false)
  feePercentAtApproval Float?
  // Streak bonus % snapshot taken at the moment of APPROVAL. Once set, this value
  // is NEVER recomputed — future streak changes don't cascade to this clip. Null
  // for legacy clips approved before this column existed; recalc paths lazily
  // snapshot the current streak % on first touch. Level/PWA/budget recalc still
  // runs — only the streak portion is frozen.
  streakBonusPercentAtApproval Float?
  streakDayLocked      Boolean    @default(false)
  streakDayLockedAt    DateTime?
  videoUnavailable     Boolean    @default(false)
  videoUnavailableSince DateTime?
  savedEarnings        Float?
  // Marketplace (Phase 1) — denormalized FK + flag. The flag is what tells
  // earnings calc (Phase 6) to do 60/30/10 split instead of normal CPM flow.
  // Null/false for all non-marketplace clips.
  marketplaceSubmissionId String?
  isMarketplaceClip       Boolean  @default(false)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign    Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  clipAccount ClipAccount @relation(fields: [clipAccountId], references: [id], onDelete: Cascade)
  stats          ClipStat[]
  trackingJob    TrackingJob?
  agencyEarning  AgencyEarning?
  marketplaceOriginPost MarketplaceClipPost? @relation("MarketplaceOriginPost")
  marketplaceCreatorEarning  MarketplaceCreatorEarning?  @relation("MarketplaceCreatorEarning")
  marketplacePlatformEarning MarketplacePlatformEarning? @relation("MarketplacePlatformEarning")

  @@unique([clipUrl, campaignId])
  @@index([userId])
  @@index([userId, createdAt])
  @@index([campaignId])
  @@index([campaignId, status, isDeleted])
  @@index([campaignId, status, videoUnavailable, isDeleted])
  @@index([status])
  @@map("clips")
}

// ─── Agency/Owner Earnings ──────────────────────────────────

model AgencyEarning {
  id         String   @id @default(cuid())
  campaignId String
  clipId     String   @unique
  amount     Float
  views      Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  clip     Clip     @relation(fields: [clipId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@map("agency_earnings")
}

// ─── Clip Stats (snapshots) ─────────────────────────────────

model ClipStat {
  id        String   @id @default(cuid())
  clipId    String
  views     Int      @default(0)
  likes     Int      @default(0)
  comments  Int      @default(0)
  shares    Int      @default(0)
  isManual  Boolean  @default(false)
  checkedAt DateTime @default(now())

  clip Clip @relation(fields: [clipId], references: [id], onDelete: Cascade)

  @@index([clipId])
  @@index([clipId, checkedAt])
  @@map("clip_stats")
}

// ─── Tracking Jobs ──────────────────────────────────────────

model TrackingJob {
  id               String   @id @default(cuid())
  clipId           String   @unique
  campaignId       String
  nextCheckAt      DateTime
  checkIntervalMin Int      @default(120) // minutes
  consecutiveFlats Int      @default(0)
  isActive         Boolean  @default(true)
  lastCheckedAt    DateTime?
  createdAt        DateTime @default(now())

  clip     Clip     @relation(fields: [clipId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([isActive, nextCheckAt])
  @@index([campaignId])
  @@map("tracking_jobs")
}

// ─── Payout Requests ────────────────────────────────────────

enum PayoutStatus {
  REQUESTED
  UNDER_REVIEW
  APPROVED
  PAID
  REJECTED
  VOIDED
}

model PayoutRequest {
  id              String       @id @default(cuid())
  userId          String
  campaignId      String?
  amount          Float
  feePercent      Float?
  bonusPercent    Float?
  feeAmount       Float?
  bonusAmount     Float?
  finalAmount     Float?
  walletAddress   String
  walletAsset     String?
  walletChain     String?
  discordUsername String?
  proofNote       String?      @db.Text
  proofFileUrl    String?
  status          PayoutStatus @default(REQUESTED)
  rejectionReason String?
  reviewedById    String?
  reviewedAt      DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign       Campaign?       @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  scheduledCalls ScheduledCall[]

  @@index([userId])
  @@index([status])
  @@index([campaignId])
  @@map("payout_requests")
}

// ─── Scheduled Calls (payout verification) ──────────────────

model ScheduledCall {
  id              String   @id @default(cuid())
  payoutId        String
  userId          String
  scheduledAt     DateTime?
  duration        Int      @default(15)
  status          String   @default("PENDING") // PENDING, CONFIRMED, COMPLETED, MISSED, CANCELLED
  discordUsername  String?
  clipperTimezone  String?
  notes           String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  payout PayoutRequest @relation(fields: [payoutId], references: [id], onDelete: Cascade)
  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([scheduledAt])
  @@index([userId])
  @@index([payoutId])
  @@map("scheduled_calls")
}

// ─── Campaign Admins (team access: which admins can manage which campaigns) ──

model CampaignAdmin {
  id         String   @id @default(cuid())
  userId     String
  campaignId String
  assignedAt DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([userId, campaignId])
  @@index([userId])
  @@map("campaign_admins")
}

// ─── Pending Campaign Edits (admin edit requests) ────────────

enum PendingEditStatus {
  PENDING
  APPROVED
  REJECTED
}

model PendingCampaignEdit {
  id         String            @id @default(cuid())
  campaignId String
  requestedById String
  changes    String            @db.Text
  status     PendingEditStatus @default(PENDING)
  reviewNote String?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  requestedBy User     @relation(fields: [requestedById], references: [id], onDelete: Cascade)

  @@map("pending_campaign_edits")
}

// ─── Audit Log ──────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String   // APPROVE_CLIP, REJECT_PAYOUT, CHANGE_ROLE, MANUAL_OVERRIDE, etc.
  targetType String   // clip, payout, user, campaign
  targetId   String
  details    String?  @db.Text // JSON: before/after values
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── Notes (internal CRM) ───────────────────────────────────

model Note {
  id         String   @id @default(cuid())
  content    String   @db.Text
  authorId   String
  userId     String?
  campaignId String?
  clipId     String?
  createdAt  DateTime @default(now())

  author   User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  campaign Campaign? @relation(fields: [campaignId], references: [id])

  @@map("notes")
}

// ─── Chat System ────────────────────────────────────────────

model Conversation {
  id                   String    @id @default(cuid())
  campaignId           String?
  needsHumanSupport    Boolean   @default(false)
  lastHumanEmailSentAt DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  campaign     Campaign?                 @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  participants ConversationParticipant[]
  messages     Message[]

  @@index([updatedAt])
  @@map("conversations")
}

model ConversationParticipant {
  id             String   @id @default(cuid())
  conversationId String
  userId         String
  lastReadAt     DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@map("conversation_participants")
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  content        String   @db.Text
  isAI           Boolean  @default(false)
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("messages")
}

// ─── Chat Knowledge Base ───────────────────────────────────

model ChatKnowledge {
  id        String   @id @default(cuid())
  category  String
  question  String
  answer    String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("chat_knowledge")
}

// ─── Cron coordination ──────────────────────────────────────

/// Lightweight single-key lock table used to prevent overlapping tracking-cron
/// runs. Row-based rather than Postgres advisory locks because
/// @prisma/adapter-pg uses pg.Pool — advisory locks are session-scoped to the
/// connection they were acquired on, which breaks across pool checkouts.
/// See src/lib/tracking.ts acquireTrackingLock for the atomic INSERT ... ON
/// CONFLICT pattern with a staleness window for self-healing.
model CronLock {
  key        String   @id
  acquiredAt DateTime @default(now())

  @@map("cron_locks")
}

// ─── Notifications ──────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // CLIP_SUBMITTED, CLIP_APPROVED, CLIP_REJECTED, STREAK_WARNING, LEVEL_UP, REFERRAL_SIGNUP, etc.
  title     String
  body      String   @db.Text
  isRead    Boolean  @default(false)
  metadata  String?  @db.Text // JSON
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@index([createdAt])
  @@map("notifications")
}

// ─── Campaign Events (budget history, status changes) ──────

model CampaignEvent {
  id          String   @id @default(cuid())
  campaignId  String
  type        String
  description String   @db.Text
  metadata    String?  @db.Text
  userId      String?
  createdAt   DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, createdAt])
  @@map("campaign_events")
}

// ─── Gamification & Platform Config ─────────────────────────

model GamificationConfig {
  id        String @id @default(cuid())
  key       String @unique // e.g. "level_thresholds", "streak_rewards", "platform_fee"
  value     String @db.Text // JSON config

  @@map("gamification_config")
}

// ─── Client Access ──────────────────────────────────────────

model CampaignClient {
  id         String   @id @default(cuid())
  userId     String
  campaignId String
  addedAt    DateTime @default(now())
  addedById  String?

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([userId, campaignId])
  @@index([userId])
  @@index([campaignId])
  @@map("campaign_clients")
}

model MagicLinkToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([token])
  @@index([email])
  @@map("magic_link_tokens")
}

// ─── Community: Channels, Tickets, Voice Calls ──────────────

model Channel {
  id          String   @id @default(cuid())
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  name        String
  type        String   @default("general") // general | announcement | leaderboard
  description String?
  sortOrder   Int      @default(0)
  isPinned    Boolean  @default(false)
  createdAt   DateTime @default(now())
  messages    ChannelMessage[]

  @@index([campaignId])
  @@map("channels")
}

model ChannelMessage {
  id        String   @id @default(cuid())
  channelId String
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String   @db.Text
  isDeleted Boolean  @default(false)
  deletedBy String?
  replyToId String?
  replyTo   ChannelMessage?  @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies   ChannelMessage[] @relation("MessageReplies")
  reactions MessageReaction[]
  createdAt DateTime @default(now())

  @@index([channelId, createdAt])
  @@index([userId])
  @@map("channel_messages")
}

model CampaignTicket {
  id            String   @id @default(cuid())
  campaignId    String
  campaign      Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status        String   @default("open") // open | waiting | resolved | pending
  notes         String?  @db.Text
  lastMessageAt DateTime?
  createdAt     DateTime @default(now())
  messages      TicketMessage[]

  @@unique([campaignId, userId])
  @@index([campaignId, status])
  @@index([userId])
  @@map("campaign_tickets")
}

model TicketMessage {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    CampaignTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([ticketId, createdAt])
  @@map("ticket_messages")
}

model ScheduledVoiceCall {
  id           String   @id @default(cuid())
  campaignId   String?
  campaign     Campaign? @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  isGlobal     Boolean  @default(false)
  title        String
  description  String?  @db.Text
  scheduledAt  DateTime
  duration     Int      @default(60) // minutes
  roomId       String?
  status       String   @default("scheduled") // scheduled | live | completed | cancelled
  recordingUrl String?
  createdById  String?
  createdBy    User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())

  @@index([campaignId])
  @@index([scheduledAt])
  @@map("scheduled_voice_calls")
}

// Tracks last-read time per user per channel for unread counts.
// No Prisma relations — userId/channelId used as strings for cascade-safe ops at the app layer.
model ChannelReadStatus {
  id         String   @id @default(cuid())
  channelId  String
  userId     String
  lastReadAt DateTime @default(now())

  @@unique([channelId, userId])
  @@index([userId])
  @@map("channel_read_status")
}

model CommunityMute {
  id         String   @id @default(cuid())
  campaignId String
  userId     String
  createdAt  DateTime @default(now())

  @@unique([campaignId, userId])
  @@map("community_mutes")
}

/// Staff-issued mute. Blocks the user from posting in channels (not tickets) until expiresAt.
/// Separate from CommunityMute (which is a user's own opt-out of announcement emails).
model CommunityModerationMute {
  id         String   @id @default(cuid())
  campaignId String
  userId     String
  mutedById  String
  expiresAt  DateTime
  reason     String?
  createdAt  DateTime @default(now())

  @@unique([campaignId, userId])
  @@index([expiresAt])
  @@map("community_moderation_mutes")
}

// Emoji reactions on channel messages. One row per (message, user, emoji).
model MessageReaction {
  id        String   @id @default(cuid())
  messageId String
  message   ChannelMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emoji     String
  createdAt DateTime @default(now())

  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@map("message_reactions")
}

// Audit trail of clipper joins/leaves on a campaign. Owner/admin-visible only.
model CommunityActivity {
  id         String   @id @default(cuid())
  campaignId String
  userId     String
  username   String
  action     String // "joined" | "left"
  createdAt  DateTime @default(now())

  @@index([campaignId, createdAt])
  @@map("community_activity")
}

// ─── Marketplace (Phase 1) ──────────────────────────────────
// Hidden behind feature flag MARKETPLACE_ENABLED + OWNER role check until launch.
// Posters list verified ClipAccounts per campaign; Creators submit Drive links;
// earnings split 60/30/10 (creator/poster/platform) at view-tracking time.
// See MARKETPLACE_SPEC.md for full design.

enum MarketplaceListingStatus {
  PENDING_APPROVAL
  ACTIVE
  PAUSED
  DELETION_REQUESTED
  DELETED
  REJECTED
  BANNED
}

enum MarketplaceSubmissionStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
  POSTED
  POST_EXPIRED
}

// Phase 7a — bidirectional rating direction. POSTER_RATES_CREATOR is the
// poster scoring the creator's clip quality + cooperation; CREATOR_RATES_POSTER
// is the creator scoring the poster's communication + payout reliability.
// Two directions max per submission via composite unique on
// (submissionId, direction).
enum MarketplaceRatingDirection {
  POSTER_RATES_CREATOR
  CREATOR_RATES_POSTER
}

model MarketplacePosterListing {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation("MarketplaceListings", fields: [userId], references: [id], onDelete: Cascade)
  clipAccountId       String
  clipAccount         ClipAccount @relation("MarketplaceListings", fields: [clipAccountId], references: [id], onDelete: Cascade)
  campaignId          String
  campaign            Campaign @relation("MarketplaceListings", fields: [campaignId], references: [id], onDelete: Cascade)
  niche               String
  audienceDescription String   @db.Text
  followerCount       Int
  followerOverride    Int?
  country             String?
  timezone            String?
  dailySlotCount      Int      @default(5)
  status              MarketplaceListingStatus @default(PENDING_APPROVAL)
  pausedAt            DateTime?
  deletionRequestedAt DateTime?
  approvedAt          DateTime?
  approvedBy          String?
  rejectionReason     String?
  averageRating       Float?
  // Phase 7a — total ratings count cached for "★ 4.7 (12)" display.
  // Updated atomically with averageRating in same TX as rating insert.
  ratingCount         Int      @default(0)
  totalSubmissions    Int      @default(0)
  totalApproved       Int      @default(0)
  totalPosted         Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  submissions         MarketplaceSubmission[]

  @@unique([userId, clipAccountId, campaignId])
  @@index([campaignId, status])
  @@index([userId])
  @@map("marketplace_poster_listings")
}

model MarketplaceSubmission {
  id              String   @id @default(cuid())
  creatorId       String
  creator         User     @relation("MarketplaceCreatorSubmissions", fields: [creatorId], references: [id], onDelete: Cascade)
  listingId       String
  listing         MarketplacePosterListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  driveUrl        String   @db.Text
  videoHash       String?
  platforms       String[]
  notes           String?  @db.Text
  status          MarketplaceSubmissionStatus @default(PENDING)
  approvedAt      DateTime?
  rejectedAt      DateTime?
  rejectionReason String?  @db.Text
  improvementNote String?  @db.Text
  expiresAt       DateTime
  postDeadline    DateTime?
  postedAt        DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  posts           MarketplaceClipPost[]
  messages        MarketplaceMessage[]
  // Phase 7a — bidirectional ratings (max 2 per submission, one per direction).
  // Composite unique on (submissionId, direction) on MarketplaceRating
  // enforces the cap.
  ratings         MarketplaceRating[]

  @@index([listingId, status])
  @@index([creatorId, status])
  @@index([videoHash])
  @@index([expiresAt])
  @@index([postDeadline])
  @@map("marketplace_submissions")
}

model MarketplaceClipPost {
  id           String   @id @default(cuid())
  submissionId String
  submission   MarketplaceSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  clipId       String   @unique
  clip         Clip     @relation("MarketplaceOriginPost", fields: [clipId], references: [id], onDelete: Cascade)
  platform     String
  postedAt     DateTime @default(now())

  @@index([submissionId])
  @@map("marketplace_clip_posts")
}

model MarketplaceRating {
  id           String   @id @default(cuid())
  submissionId String
  submission   MarketplaceSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  // Phase 7a — posterId/creatorId are ROLE identifiers tied to the underlying
  // submission's poster (listing-owner) and creator (submitter), NOT the
  // rater/ratee. The rater is determined by `direction`:
  //   POSTER_RATES_CREATOR → poster (= posterId) is rater, creator is ratee
  //   CREATOR_RATES_POSTER → creator (= creatorId) is rater, poster is ratee
  // Keeping the role names stable across both directions makes JOIN logic and
  // privacy filters trivial — the role pair is fixed per submission, only the
  // arrow flips.
  posterId     String
  poster       User     @relation("MarketplaceRatingsGiven", fields: [posterId], references: [id], onDelete: Cascade)
  creatorId    String
  creator      User     @relation("MarketplaceRatingsReceived", fields: [creatorId], references: [id], onDelete: Cascade)
  // Phase 7a — direction enum unlocks the bidirectional rating model.
  direction    MarketplaceRatingDirection
  // Score validation (1..5) lives at the API layer — no DB check constraint.
  score        Int
  note         String?  @db.Text
  createdAt    DateTime @default(now())

  // Phase 7a — composite unique replaces the previous @unique on submissionId.
  // Lets a single submission carry up to two ratings (one per direction).
  @@unique([submissionId, direction])
  @@index([creatorId])
  @@index([posterId])
  @@map("marketplace_ratings")
}

model MarketplaceMessage {
  id           String   @id @default(cuid())
  submissionId String
  submission   MarketplaceSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  senderId     String
  sender       User     @relation("MarketplaceMessages", fields: [senderId], references: [id], onDelete: Cascade)
  content      String   @db.Text
  readAt       DateTime?
  createdAt    DateTime @default(now())

  @@index([submissionId, createdAt])
  @@index([senderId])
  @@map("marketplace_messages")
}

model MarketplaceStrike {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation("MarketplaceStrikes", fields: [userId], references: [id], onDelete: Cascade)
  reason       String
  submissionId String?
  bannedUntil  DateTime?
  createdAt    DateTime  @default(now())

  @@index([userId, createdAt])
  @@map("marketplace_strikes")
}

model MarketplaceVideoHash {
  id                    String   @id @default(cuid())
  hash                  String   @unique
  firstSeenSubmissionId String
  rejectionCount        Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([hash])
  @@map("marketplace_video_hashes")
}

// ─── Marketplace Phase 6 — 60/30/10 earnings split ──────────
// Marketplace clips split CPM gross 3 ways: 60% creator, 30% poster, 10% platform.
// Clip.earnings holds the poster's 30% (so existing payout/balance flows are unchanged).
// Creator's 60% lives here, joined to the user via creatorId. Platform's 10% lives in
// MarketplacePlatformEarning and is never returned in user-facing API responses.

model MarketplaceCreatorEarning {
  id                            String   @id @default(cuid())
  clipId                        String   @unique
  creatorId                     String
  campaignId                    String
  amount                        Float    @default(0)
  baseAmount                    Float    @default(0)
  bonusPercent                  Float    @default(0)
  bonusAmount                   Float    @default(0)
  streakBonusPercentAtApproval  Float?
  savedAmount                   Float?
  views                         Int      @default(0)
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt

  clip     Clip     @relation("MarketplaceCreatorEarning", fields: [clipId], references: [id], onDelete: Cascade)
  creator  User     @relation("MarketplaceCreatorEarnings", fields: [creatorId], references: [id], onDelete: Cascade)
  campaign Campaign @relation("MarketplaceCreatorEarnings", fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([clipId])
  @@index([creatorId])
  @@index([campaignId])
  @@map("marketplace_creator_earnings")
}

model MarketplacePlatformEarning {
  id          String   @id @default(cuid())
  clipId      String   @unique
  campaignId  String
  amount      Float    @default(0)
  savedAmount Float?
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clip     Clip     @relation("MarketplacePlatformEarning", fields: [clipId], references: [id], onDelete: Cascade)
  campaign Campaign @relation("MarketplacePlatformEarnings", fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([clipId])
  @@index([campaignId])
  @@map("marketplace_platform_earnings")
}
