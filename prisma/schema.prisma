generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth (NextAuth) ────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("auth_accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("auth_sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("auth_verification_tokens")
}

// ─── Users ──────────────────────────────────────────────────

enum UserRole {
  CLIPPER
  ADMIN
  OWNER
  CLIENT
}

enum UserStatus {
  ACTIVE
  BANNED
  SUSPENDED
}

model User {
  id            String     @id @default(cuid())
  name          String?
  discordId     String?    @unique
  username      String     @default("user")
  email         String?    @unique
  emailVerified DateTime?
  image         String?
  role          UserRole   @default(CLIPPER)
  status        UserStatus @default(ACTIVE)
  trustScore    Int        @default(50)
  totalEarnings Float      @default(0)
  totalViews    Int        @default(0)
  level         Int        @default(0)
  bonusPercentage Float    @default(0)
  currentStreak Int        @default(0)
  longestStreak Int        @default(0)
  previousStreak Int       @default(0)
  lastActiveDate DateTime?
  referralCode  String?    @unique
  referredById  String?
  manualBonusOverride Float?
  isPWAUser     Boolean    @default(false)
  lastPWAOpenAt DateTime?
  timezone      String?
  streakRestoredAt DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  // Relations
  referredBy       User?     @relation("Referrals", fields: [referredById], references: [id], onDelete: SetNull)
  referrals        User[]    @relation("Referrals")
  authAccounts     Account[]
  sessions         Session[]
  clipAccounts     ClipAccount[]
  clips            Clip[]
  payoutRequests   PayoutRequest[]
  notes            Note[]
  campaignsCreated Campaign[]          @relation("CampaignsCreated")
  pendingEdits     PendingCampaignEdit[]
  campaignAdmins   CampaignAdmin[]
  teamMemberships  TeamMember[]
  auditLogs        AuditLog[]
  conversationParticipants ConversationParticipant[]
  messagesSent     Message[]
  notifications    Notification[]
  scheduledCalls   ScheduledCall[]
  campaignClients  CampaignClient[]
  // Community system — channels, tickets, scheduled voice calls
  channelMessages         ChannelMessage[]
  communityTickets        CampaignTicket[]
  communityTicketMessages TicketMessage[]
  scheduledVoiceCalls     ScheduledVoiceCall[]
  messageReactions        MessageReaction[]
  ownedCampaigns          Campaign[]          @relation("CampaignOwner")

  @@index([role])
  @@index([referredById])
  @@map("users")
}

// ─── Teams ──────────────────────────────────────────────────

model Team {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members   TeamMember[]
  campaigns TeamCampaign[]

  @@map("teams")
}

model TeamMember {
  id     String @id @default(cuid())
  teamId String
  userId String
  role   String @default("MEMBER") // LEAD, MEMBER, VIEWER

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@map("team_members")
}

model TeamCampaign {
  id         String @id @default(cuid())
  teamId     String
  campaignId String

  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([teamId, campaignId])
  @@map("team_campaigns")
}

// ─── Campaigns ──────────────────────────────────────────────

enum CampaignStatus {
  ACTIVE
  PAUSED
  COMPLETED
  DRAFT
}

model Campaign {
  id              String         @id @default(cuid())
  name            String
  clientName      String?
  platform        String
  status          CampaignStatus @default(DRAFT)
  pricingModel    String         @default("AGENCY_FEE") // "AGENCY_FEE" or "CPM_SPLIT"
  monetizationType String       @default("CPM") // Legacy field
  budget          Float?
  cpmRate         Float?
  clipperCpm      Float?
  ownerCpm        Float?
  agencyFee       Float?
  payoutRule      String?
  minViews        Int?
  maxPayoutPerClip Float?
  maxClipsPerUserPerDay Int     @default(3)
  description     String?        @db.Text
  requirements    String?        @db.Text
  examples        String?        @db.Text
  soundLink       String?
  assetLink       String?
  imageUrl        String?
  bannedContent   String?        @db.Text
  captionRules    String?        @db.Text
  hashtagRules    String?        @db.Text
  videoLengthMin  Int?
  videoLengthMax  Int?
  reviewTiming    String?
  aiKnowledge     String?        @db.Text
  startDate       DateTime?
  endDate         DateTime?
  createdById     String?
  isArchived         Boolean        @default(false)
  archivedAt         DateTime?
  archivedById       String?
  lastBudgetPauseAt  DateTime?
  targetAudience     String?
  targetCountries    String?
  accountCountries   String?
  ownerUserId        String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  createdBy        User?   @relation("CampaignsCreated", fields: [createdById], references: [id])
  ownerUser        User?   @relation("CampaignOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  clips            Clip[]
  notes            Note[]
  campaignAccounts CampaignAccount[]
  pendingEdits     PendingCampaignEdit[]
  campaignAdmins   CampaignAdmin[]
  payoutRequests   PayoutRequest[]
  teamCampaigns    TeamCampaign[]
  trackingJobs     TrackingJob[]
  conversations    Conversation[]
  agencyEarnings   AgencyEarning[]
  campaignEvents   CampaignEvent[]
  campaignClients  CampaignClient[]
  // Community system
  channels             Channel[]
  communityTickets     CampaignTicket[]
  scheduledVoiceCalls  ScheduledVoiceCall[]

  @@index([status])
  @@index([isArchived])
  @@index([createdById])
  @@map("campaigns")
}

// ─── Clip Accounts (social media accounts) ──────────────────

enum ClipAccountStatus {
  PENDING
  VERIFIED
  APPROVED
  REJECTED
}

model ClipAccount {
  id                String           @id @default(cuid())
  userId            String
  platform          String
  username          String
  profileLink       String
  followerCount     Int?
  contentNiche      String?
  country           String?
  status            ClipAccountStatus @default(PENDING)
  rejectionReason   String?
  verificationCode  String?
  verifiedAt        DateTime?
  deletedByUser     Boolean          @default(false)
  deletedAt         DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  clips            Clip[]
  campaignAccounts CampaignAccount[]

  @@index([userId])
  @@map("clip_accounts")
}

// ─── Campaign Accounts (join: account ↔ campaign) ──────────

model CampaignAccount {
  id            String      @id @default(cuid())
  clipAccountId String
  campaignId    String
  joinedAt      DateTime    @default(now())

  clipAccount ClipAccount @relation(fields: [clipAccountId], references: [id], onDelete: Cascade)
  campaign    Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([clipAccountId, campaignId])
  @@map("campaign_accounts")
}

// ─── Clips ──────────────────────────────────────────────────

enum ClipStatus {
  PENDING
  APPROVED
  REJECTED
  ARCHIVED
  FLAGGED
}

model Clip {
  id              String     @id @default(cuid())
  userId          String
  campaignId      String
  clipAccountId   String
  clipUrl         String
  note            String?    @db.Text
  status          ClipStatus @default(PENDING)
  rejectionReason String?
  earnings        Float      @default(0)
  baseEarnings    Float      @default(0)
  bonusPercent    Float      @default(0)
  bonusAmount     Float      @default(0)
  isDeleted       Boolean    @default(false)
  reviewedById    String?
  reviewedAt      DateTime?
  fraudScore      Int        @default(0)
  fraudReasons    String?    @db.Text // JSON array of reason strings
  fraudCheckedAt  DateTime?
  isOwnerOverride      Boolean    @default(false)
  feePercentAtApproval Float?
  streakDayLocked      Boolean    @default(false)
  streakDayLockedAt    DateTime?
  videoUnavailable     Boolean    @default(false)
  videoUnavailableSince DateTime?
  savedEarnings        Float?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign    Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  clipAccount ClipAccount @relation(fields: [clipAccountId], references: [id], onDelete: Cascade)
  stats          ClipStat[]
  trackingJob    TrackingJob?
  agencyEarning  AgencyEarning?

  @@unique([clipUrl, campaignId])
  @@index([userId])
  @@index([userId, createdAt])
  @@index([campaignId])
  @@index([campaignId, status, isDeleted])
  @@index([campaignId, status, videoUnavailable, isDeleted])
  @@index([status])
  @@map("clips")
}

// ─── Agency/Owner Earnings ──────────────────────────────────

model AgencyEarning {
  id         String   @id @default(cuid())
  campaignId String
  clipId     String   @unique
  amount     Float
  views      Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  clip     Clip     @relation(fields: [clipId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@map("agency_earnings")
}

// ─── Clip Stats (snapshots) ─────────────────────────────────

model ClipStat {
  id        String   @id @default(cuid())
  clipId    String
  views     Int      @default(0)
  likes     Int      @default(0)
  comments  Int      @default(0)
  shares    Int      @default(0)
  isManual  Boolean  @default(false)
  checkedAt DateTime @default(now())

  clip Clip @relation(fields: [clipId], references: [id], onDelete: Cascade)

  @@index([clipId])
  @@index([clipId, checkedAt])
  @@map("clip_stats")
}

// ─── Tracking Jobs ──────────────────────────────────────────

model TrackingJob {
  id               String   @id @default(cuid())
  clipId           String   @unique
  campaignId       String
  nextCheckAt      DateTime
  checkIntervalMin Int      @default(120) // minutes
  consecutiveFlats Int      @default(0)
  isActive         Boolean  @default(true)
  lastCheckedAt    DateTime?
  createdAt        DateTime @default(now())

  clip     Clip     @relation(fields: [clipId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([isActive, nextCheckAt])
  @@index([campaignId])
  @@map("tracking_jobs")
}

// ─── Payout Requests ────────────────────────────────────────

enum PayoutStatus {
  REQUESTED
  UNDER_REVIEW
  APPROVED
  PAID
  REJECTED
  VOIDED
}

model PayoutRequest {
  id              String       @id @default(cuid())
  userId          String
  campaignId      String?
  amount          Float
  feePercent      Float?
  bonusPercent    Float?
  feeAmount       Float?
  bonusAmount     Float?
  finalAmount     Float?
  walletAddress   String
  walletAsset     String?
  walletChain     String?
  discordUsername String?
  proofNote       String?      @db.Text
  proofFileUrl    String?
  status          PayoutStatus @default(REQUESTED)
  rejectionReason String?
  reviewedById    String?
  reviewedAt      DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign       Campaign?       @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  scheduledCalls ScheduledCall[]

  @@index([userId])
  @@index([status])
  @@index([campaignId])
  @@map("payout_requests")
}

// ─── Scheduled Calls (payout verification) ──────────────────

model ScheduledCall {
  id              String   @id @default(cuid())
  payoutId        String
  userId          String
  scheduledAt     DateTime?
  duration        Int      @default(15)
  status          String   @default("PENDING") // PENDING, CONFIRMED, COMPLETED, MISSED, CANCELLED
  discordUsername  String?
  clipperTimezone  String?
  notes           String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  payout PayoutRequest @relation(fields: [payoutId], references: [id], onDelete: Cascade)
  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([scheduledAt])
  @@index([userId])
  @@index([payoutId])
  @@map("scheduled_calls")
}

// ─── Campaign Admins (team access: which admins can manage which campaigns) ──

model CampaignAdmin {
  id         String   @id @default(cuid())
  userId     String
  campaignId String
  assignedAt DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([userId, campaignId])
  @@index([userId])
  @@map("campaign_admins")
}

// ─── Pending Campaign Edits (admin edit requests) ────────────

enum PendingEditStatus {
  PENDING
  APPROVED
  REJECTED
}

model PendingCampaignEdit {
  id         String            @id @default(cuid())
  campaignId String
  requestedById String
  changes    String            @db.Text
  status     PendingEditStatus @default(PENDING)
  reviewNote String?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  requestedBy User     @relation(fields: [requestedById], references: [id], onDelete: Cascade)

  @@map("pending_campaign_edits")
}

// ─── Audit Log ──────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String   // APPROVE_CLIP, REJECT_PAYOUT, CHANGE_ROLE, MANUAL_OVERRIDE, etc.
  targetType String   // clip, payout, user, campaign
  targetId   String
  details    String?  @db.Text // JSON: before/after values
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── Notes (internal CRM) ───────────────────────────────────

model Note {
  id         String   @id @default(cuid())
  content    String   @db.Text
  authorId   String
  userId     String?
  campaignId String?
  clipId     String?
  createdAt  DateTime @default(now())

  author   User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  campaign Campaign? @relation(fields: [campaignId], references: [id])

  @@map("notes")
}

// ─── Chat System ────────────────────────────────────────────

model Conversation {
  id                   String    @id @default(cuid())
  campaignId           String?
  needsHumanSupport    Boolean   @default(false)
  lastHumanEmailSentAt DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  campaign     Campaign?                 @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  participants ConversationParticipant[]
  messages     Message[]

  @@index([updatedAt])
  @@map("conversations")
}

model ConversationParticipant {
  id             String   @id @default(cuid())
  conversationId String
  userId         String
  lastReadAt     DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@map("conversation_participants")
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  content        String   @db.Text
  isAI           Boolean  @default(false)
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("messages")
}

// ─── Chat Knowledge Base ───────────────────────────────────

model ChatKnowledge {
  id        String   @id @default(cuid())
  category  String
  question  String
  answer    String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("chat_knowledge")
}

// ─── Notifications ──────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // CLIP_SUBMITTED, CLIP_APPROVED, CLIP_REJECTED, STREAK_WARNING, LEVEL_UP, REFERRAL_SIGNUP, etc.
  title     String
  body      String   @db.Text
  isRead    Boolean  @default(false)
  metadata  String?  @db.Text // JSON
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@index([createdAt])
  @@map("notifications")
}

// ─── Campaign Events (budget history, status changes) ──────

model CampaignEvent {
  id          String   @id @default(cuid())
  campaignId  String
  type        String
  description String   @db.Text
  metadata    String?  @db.Text
  userId      String?
  createdAt   DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, createdAt])
  @@map("campaign_events")
}

// ─── Gamification & Platform Config ─────────────────────────

model GamificationConfig {
  id        String @id @default(cuid())
  key       String @unique // e.g. "level_thresholds", "streak_rewards", "platform_fee"
  value     String @db.Text // JSON config

  @@map("gamification_config")
}

// ─── Client Access ──────────────────────────────────────────

model CampaignClient {
  id         String   @id @default(cuid())
  userId     String
  campaignId String
  addedAt    DateTime @default(now())
  addedById  String?

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([userId, campaignId])
  @@index([userId])
  @@index([campaignId])
  @@map("campaign_clients")
}

model MagicLinkToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([token])
  @@index([email])
  @@map("magic_link_tokens")
}

// ─── Community: Channels, Tickets, Voice Calls ──────────────

model Channel {
  id          String   @id @default(cuid())
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  name        String
  type        String   @default("general") // general | announcement | leaderboard
  description String?
  sortOrder   Int      @default(0)
  isPinned    Boolean  @default(false)
  createdAt   DateTime @default(now())
  messages    ChannelMessage[]

  @@index([campaignId])
  @@map("channels")
}

model ChannelMessage {
  id        String   @id @default(cuid())
  channelId String
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String   @db.Text
  isPinned  Boolean  @default(false)
  isDeleted Boolean  @default(false)
  deletedBy String?
  replyToId String?
  replyTo   ChannelMessage?  @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies   ChannelMessage[] @relation("MessageReplies")
  reactions MessageReaction[]
  createdAt DateTime @default(now())

  @@index([channelId, createdAt])
  @@index([userId])
  @@map("channel_messages")
}

model CampaignTicket {
  id            String   @id @default(cuid())
  campaignId    String
  campaign      Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status        String   @default("open") // open | waiting | resolved | pending
  notes         String?  @db.Text
  lastMessageAt DateTime?
  createdAt     DateTime @default(now())
  messages      TicketMessage[]

  @@unique([campaignId, userId])
  @@index([campaignId, status])
  @@index([userId])
  @@map("campaign_tickets")
}

model TicketMessage {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    CampaignTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([ticketId, createdAt])
  @@map("ticket_messages")
}

model ScheduledVoiceCall {
  id           String   @id @default(cuid())
  campaignId   String?
  campaign     Campaign? @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  isGlobal     Boolean  @default(false)
  title        String
  description  String?  @db.Text
  scheduledAt  DateTime
  duration     Int      @default(60) // minutes
  roomId       String?
  status       String   @default("scheduled") // scheduled | live | completed | cancelled
  recordingUrl String?
  createdById  String?
  createdBy    User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())

  @@index([campaignId])
  @@index([scheduledAt])
  @@map("scheduled_voice_calls")
}

// Tracks last-read time per user per channel for unread counts.
// No Prisma relations — userId/channelId used as strings for cascade-safe ops at the app layer.
model ChannelReadStatus {
  id         String   @id @default(cuid())
  channelId  String
  userId     String
  lastReadAt DateTime @default(now())

  @@unique([channelId, userId])
  @@index([userId])
  @@map("channel_read_status")
}

model CommunityMute {
  id         String   @id @default(cuid())
  campaignId String
  userId     String
  createdAt  DateTime @default(now())

  @@unique([campaignId, userId])
  @@map("community_mutes")
}

// Emoji reactions on channel messages. One row per (message, user, emoji).
model MessageReaction {
  id        String   @id @default(cuid())
  messageId String
  message   ChannelMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emoji     String
  createdAt DateTime @default(now())

  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@map("message_reactions")
}

// Audit trail of clipper joins/leaves on a campaign. Owner/admin-visible only.
model CommunityActivity {
  id         String   @id @default(cuid())
  campaignId String
  userId     String
  username   String
  action     String // "joined" | "left"
  createdAt  DateTime @default(now())

  @@index([campaignId, createdAt])
  @@map("community_activity")
}
